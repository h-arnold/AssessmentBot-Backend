{
  "name": "assessmentbot-backend",
  "version": "0.1.10",
  "description": "The backend for Assessment Bot, which provides LLM services.",
  "author": "Hamish Arnold",
  "private": true,
  "license": "ISC",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "debug": "node --inspect-brk ./node_modules/.bin/nest start",
    "start:prod": "NODE_ENV=production node dist/src/main.js",
    "dev:delegate": "NODE_OPTIONS=--experimental-specifier-resolution=node ts-node --esm scripts/codex-delegate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:british": "./scripts/check-british-english.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run test:e2e:mocked",
    "test:e2e:mocked": "npm run build && jest --config ./jest-e2e.mocked.config.cjs --runInBand",
    "test:e2e:live": "npm run build && jest --config ./jest-e2e.live.config.cjs --runInBand",
    "test:prod": "npm run build && jest --config ./jest-prod.config.cjs --runInBand",
    "verify:assessor": "ts-node scripts/verify-assessor.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@openai/codex-sdk": "^0.115.0",
    "dotenv": "^17.3.1",
    "file-type": "^21.3.3",
    "jsonrepair": "^3.13.3",
    "mime-detect": "^1.3.0",
    "mustache": "^4.2.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "validator": "^13.15.26",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.5.0",
    "@types/passport": "^1.0.17",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "axios": "^1.13.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "overrides": {
    "micromatch": ">=4.0.8",
    "test-exclude": "7.0.1",
    "lodash": "4.17.23",
    "@angular-devkit/core": {
      "ajv": "8.18.0"
    },
    "@nestjs/schematics": {
      "ajv": "8.18.0"
    }
  },
  "homepage": "https://github.com/h-arnold/AssessmentBot-Backend#readme",
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{js,ts,json,md}": "prettier --write",
    "*.{ts,js}": "./scripts/check-british-english.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-arnold/AssessmentBot-Backend.git"
  },
  "bugs": {
    "url": "https://github.com/h-arnold/AssessmentBot-Backend/issues"
  }
}
